# ── MongoDB ──────────────────────────────────────────────────────────────────
# Get your connection string from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/nutrican?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# A long, random secret string – keep this private!
JWT_SECRET=replace_with_a_very_long_random_secret_string_here
JWT_EXPIRES_IN=7d

# ── DigitalOcean Spaces ───────────────────────────────────────────────────────
# Create a Space at https://cloud.digitalocean.com/spaces
DO_SPACES_ENDPOINT=https://<region>.digitaloceanspaces.com
DO_SPACES_REGION=<region>           # e.g. nyc3
DO_SPACES_BUCKET=<your-space-name>
DO_SPACES_KEY=<your-access-key>
DO_SPACES_SECRET=<your-secret-key>

# ── Groq AI (FREE) ───────────────────────────────────────────────────────────
# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
# Comma-separated list of allowed origins (your Vite dev URL + production URL)
ALLOWED_ORIGINS=http://localhost:5173
